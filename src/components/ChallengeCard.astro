---
// src/components/ChallengeCard.astro
const { label, value, rotation, marker } = Astro.props;
---

<div
  class={`rounded-3xl border border-[#dbc9b9] bg-white/90 p-6 text-center shadow-[0_14px_32px_rgba(43,28,20,0.08)] ${rotation}`}
>
  <div class='mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-[#201611] text-sm font-semibold text-white shadow-lg shadow-[#201611]/20'>
    <span>{marker ?? label.slice(0, 1)}</span>
  </div>
  <span
    class='mb-1 block text-[10px] uppercase tracking-[0.2em] text-[#8a7767] font-semibold'
  >
    {label}
  </span>
  <span class='serif text-xl font-bold text-[#201611]'>
    {value}
  </span>
</div>
