---
const { label, value, rotation, marker, slot } = Astro.props;
---

<div
  data-daily-slot={slot}
  class={`home-challenge-card bg-[var(--surface-soft)] p-6 text-center ${rotation}`}
>
  <div
    class='mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-[var(--surface-inverse)] text-sm font-semibold text-[var(--surface-base)] shadow-lg'
  >
    <span data-daily-marker>{marker ?? label.slice(0, 1)}</span>
  </div>
  <span
    data-daily-category
    class='mb-1 block text-[10px] font-semibold uppercase tracking-[0.2em] text-[var(--ink-muted)]'
  >
    {label}
  </span>
  <span
    data-daily-word
    class='serif text-xl font-bold capitalize text-[var(--ink-strong)]'
  >
    {value}
  </span>
</div>
