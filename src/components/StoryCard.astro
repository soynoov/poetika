---
// src/components/StoryCard.astro
const { title, author, words, likes, preview, hasCrown } = Astro.props;
---

<div
  class='bg-white border border-slate-200 p-6 rounded-sm hover:shadow-md transition-shadow relative'
>
  <div class='flex justify-between items-start mb-2'>
    <div class='flex items-center gap-2'>
      {hasCrown && <span class='text-yellow-500 text-lg'>👑</span>}
      <h3 class='text-xl serif font-bold text-slate-800'>{title}</h3>
    </div>
    <div class='flex items-center gap-1 text-slate-400 text-sm'>
      <span>♡</span>
      {likes}
    </div>
  </div>

  <p class='text-[11px] text-slate-400 uppercase tracking-wider mb-4'>
    {author} — {words} palabras
  </p>

  <p class='text-slate-600 italic leading-relaxed'>
    "{preview}..."
  </p>
</div>
