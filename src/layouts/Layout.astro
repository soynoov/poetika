---
import '../styles/global.css';

type Props = {
  title?: string;
  description?: string;
};

const {
  title = 'PoetiKa',
  description = 'PoetiKa es una plataforma de escritura creativa con retos diarios y feed social.',
} = Astro.props as Props;
---

<!doctype html>
<html lang='es'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <meta name='description' content={description} />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <link rel='icon' href='/favicon.svg' />
    <meta name='generator' content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const storageKey = 'poetika:theme';
        const root = document.documentElement;

        try {
          // Apply theme before paint to avoid the day/night flash on navigation.
          const savedTheme = localStorage.getItem(storageKey);
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = savedTheme === 'day' || savedTheme === 'night'
            ? savedTheme
            : prefersDark
              ? 'night'
              : 'day';

          root.dataset.theme = theme;
        } catch {
          root.dataset.theme = 'day';
        }
      })();
    </script>
  </head>
  <body>
    <slot />
    <script>
      import { initHeaderSession } from '../scripts/header-session.ts';

      initHeaderSession();
    </script>
    <script is:inline>
      (() => {
        const storageKey = 'poetika:theme';
        const root = document.documentElement;

        function applyTheme(theme) {
          root.dataset.theme = theme;
          const toggle = document.querySelector('[data-theme-toggle]');
          const moonIcon = document.querySelector('[data-theme-icon="moon"]');
          const sunIcon = document.querySelector('[data-theme-icon="sun"]');

          if (moonIcon instanceof SVGElement) {
            moonIcon.classList.toggle('hidden', theme === 'night');
          }

          if (sunIcon instanceof SVGElement) {
            sunIcon.classList.toggle('hidden', theme !== 'night');
          }

          if (toggle instanceof HTMLButtonElement) {
            const nextLabel = theme === 'night'
              ? toggle.dataset.themeLabelDark
              : toggle.dataset.themeLabelLight;

            if (nextLabel) {
              toggle.setAttribute('aria-label', nextLabel);
            }
          }
        }

        applyTheme(root.dataset.theme === 'night' ? 'night' : 'day');

        document.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const toggle = target.closest('[data-theme-toggle]');
          if (!(toggle instanceof HTMLButtonElement)) return;

          const nextTheme = root.dataset.theme === 'night' ? 'day' : 'night';

          try {
            localStorage.setItem(storageKey, nextTheme);
          } catch {
            // Ignore localStorage failures.
          }

          applyTheme(nextTheme);
        });
      })();
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
