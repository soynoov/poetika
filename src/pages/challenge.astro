---
import AppHeader from '../components/AppHeader.astro';
import ChallengeCard from '../components/ChallengeCard.astro';
import Layout from '../layouts/Layout.astro';
import { getFallbackDailyChallenge } from '../lib/challenge';

const challenge = getFallbackDailyChallenge();
---

<Layout
  title='PoetiKa - Reto del dia'
  description='Consulta el reto activo de PoetiKa: 3 palabras locales unificadas para todo el dia.'
>
  <main class='home-paper min-h-screen' data-daily-challenge>
    <div class='mx-auto max-w-[1420px] px-4 sm:px-8 lg:px-14'>
      <AppHeader currentPath='/challenge' />

      <div class='home-rail mx-auto max-w-[1390px]'>
        <section class='mx-auto max-w-[1120px] px-2 pb-20 pt-16 sm:px-4 sm:pt-20'>
          <header class='mb-14 text-center'>
            <p class='app-kicker mb-4 text-[0.72rem] uppercase tracking-[0.32em]'>
              Reto activo
            </p>
            <h1 class='app-title serif text-[3rem] font-semibold leading-none tracking-[-0.05em] sm:text-[4.4rem]'>
              Reto del dia
            </h1>
            <p class='app-copy mx-auto mt-4 max-w-2xl text-base leading-8'>
              Las palabras se calculan de forma local y se mantienen unificadas durante todo el dia.
            </p>
            <div class='mt-8 flex flex-col justify-center gap-3 sm:flex-row'>
              <a href='/write' class='home-primary-button inline-flex items-center justify-center px-8 py-4 text-sm font-semibold'>
                Escribir relato
              </a>
              <a href='/all' class='app-link-button inline-flex items-center justify-center border border-[var(--frame-border-strong)] bg-[var(--surface-strong)] px-8 py-4 text-sm font-semibold text-[var(--ink-strong)] transition hover:bg-[var(--surface-hover)]'>
                Ver feed
              </a>
            </div>
          </header>

          <div class='mb-12 grid grid-cols-1 gap-6 md:grid-cols-3'>
            <ChallengeCard
              slot='0'
              marker={challenge.slots[0].marker}
              label={challenge.slots[0].category}
              value={challenge.slots[0].word}
              rotation='-rotate-1'
            />
            <ChallengeCard
              slot='1'
              marker={challenge.slots[1].marker}
              label={challenge.slots[1].category}
              value={challenge.slots[1].word}
              rotation='rotate-0'
            />
            <ChallengeCard
              slot='2'
              marker={challenge.slots[2].marker}
              label={challenge.slots[2].category}
              value={challenge.slots[2].word}
              rotation='rotate-1'
            />
          </div>

          <section class='app-panel p-7 sm:p-9'>
            <p class='app-kicker mb-2 text-[0.75rem] uppercase tracking-[0.26em]'>
              Resumen
            </p>
            <h2 data-daily-summary class='app-title serif mb-4 text-[2rem] font-semibold'>
              {challenge.summary}
            </h2>
            <p class='app-copy mb-4 text-base leading-8'>
              El MVP usa un selector local diario para asegurar las mismas tres palabras en toda la web sin depender de Supabase.
            </p>
            <div class='flex flex-col gap-2 text-[0.8rem] uppercase tracking-[0.24em] text-[var(--ink-muted)]'>
              <p>Fecha: <span data-daily-date>{challenge.dateKey}</span></p>
              <p>Origen: <span data-daily-source>seleccion local diaria</span></p>
            </div>
          </section>
        </section>
      </div>
    </div>
  </main>

  <script>
    import { initDailyChallenge } from '../scripts/daily-challenge.ts';
    initDailyChallenge();
  </script>
</Layout>
