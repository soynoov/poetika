---
import BrandLogo from '../components/BrandLogo.astro';
import Layout from '../layouts/Layout.astro';
import { getFallbackDailyChallenge } from '../lib/challenge';

const challenge = getFallbackDailyChallenge();
---

<Layout
	title='PoetiKa - Escribir relato'
	description='Escribe un relato usando las 3 palabras del reto diario y guárdalo en tu navegador o en Supabase cuando esté disponible.'
>
	<main class='relative overflow-hidden'>
		<div class='pointer-events-none absolute inset-0'>
			<div class='absolute -top-24 -right-16 h-72 w-72 rounded-full bg-[#d87f5c]/20 blur-3xl'></div>
			<div class='absolute top-48 -left-24 h-72 w-72 rounded-full bg-[#7d4a36]/15 blur-3xl'></div>
		</div>

		<section class='relative max-w-6xl mx-auto px-4 py-10 md:py-14' data-write-page>
			<nav class='flex items-center justify-between gap-4 mb-10'>
				<div class='max-w-60 sm:max-w-[320px] md:max-w-[420px]'>
					<BrandLogo class='w-full' linkClass='transition-opacity hover:opacity-90' />
				</div>

				<div class='hidden md:flex items-center gap-3 text-sm text-[#6e6259]'>
					<a href='/challenge' class='transition hover:text-[#201611]'>Reto de hoy</a>
					<span class='text-[#b89f8f]'>/</span>
					<a href='/all' class='transition hover:text-[#201611]'>Relatos</a>
					<span class='text-[#b89f8f]'>/</span>
					<a href='/u/demo' class='transition hover:text-[#201611]'>Perfil</a>
				</div>
			</nav>

			<section class='grid gap-8 lg:grid-cols-[0.95fr_1.05fr] items-start'>
				<aside class='bg-[#1f1612] text-white shadow-[0_24px_70px_rgba(31,22,18,0.2)] p-8 md:p-10 relative overflow-hidden'>
					<div class='absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(241,215,202,0.18),transparent_35%)]'></div>
					<div class='relative'>
						<p class='text-[11px] uppercase tracking-[0.35em] text-[#c6b1a1] mb-4'>Reto de hoy</p>
						<h1 data-write-summary class='text-3xl italic font-bold leading-tight mb-6'>
							{challenge.summary}
						</h1>

						<div class='space-y-4'>
							<div class='flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3'>
								<div class='flex h-9 w-9 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-xs font-semibold text-[#f1d7ca]'>
									<span data-write-marker-1>{challenge.slots[0].marker}</span>
								</div>
								<div>
									<p data-write-category-1 class='text-xs uppercase tracking-[0.24em] text-[#a38f80]'>
										{challenge.slots[0].category}
									</p>
									<p data-write-word-1 class='text-sm'>
										{challenge.slots[0].word}
									</p>
								</div>
							</div>
							<div class='flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3'>
								<div class='flex h-9 w-9 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-xs font-semibold text-[#f1d7ca]'>
									<span data-write-marker-2>{challenge.slots[1].marker}</span>
								</div>
								<div>
									<p data-write-category-2 class='text-xs uppercase tracking-[0.24em] text-[#a38f80]'>
										{challenge.slots[1].category}
									</p>
									<p data-write-word-2 class='text-sm'>
										{challenge.slots[1].word}
									</p>
								</div>
							</div>
							<div class='flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3'>
								<div class='flex h-9 w-9 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-xs font-semibold text-[#f1d7ca]'>
									<span data-write-marker-3>{challenge.slots[2].marker}</span>
								</div>
								<div>
									<p data-write-category-3 class='text-xs uppercase tracking-[0.24em] text-[#a38f80]'>
										{challenge.slots[2].category}
									</p>
									<p data-write-word-3 class='text-sm'>
										{challenge.slots[2].word}
									</p>
								</div>
							</div>
						</div>

						<div class='mt-8 rounded-3xl border border-[#f1d7ca]/15 bg-[#2b1f19] p-5'>
							<div class='flex items-center justify-between mb-4'>
								<p class='text-xs uppercase tracking-[0.3em] text-[#c6b1a1]'>Actualización</p>
								<div class='flex items-center gap-2 text-[#f1d7ca]'>
									<span class='inline-flex h-6 w-6 items-center justify-center rounded-full border border-white/10 bg-white/5 text-[10px] font-semibold'>
										D
									</span>
									<span class='text-sm' data-write-date>{challenge.dateKey}</span>
								</div>
							</div>
							<p class='text-sm text-[#d8c5b7] leading-7'>
								Escribe un relato con estas 3 palabras y guárdalo. Si Supabase no está disponible, se
								guardará en tu navegador.
							</p>
							<p class='mt-3 text-[11px] uppercase tracking-[0.24em] text-[#a38f80]'>
								<span data-write-source>con fallback local</span>
							</p>
						</div>
					</div>
				</aside>

				<div class='bg-white/80 backdrop-blur border border-[#d8c8bb] shadow-[0_24px_70px_rgba(43,28,20,0.12)] p-8 md:p-10'>
					<div class='flex items-start justify-between gap-4 mb-6'>
						<div>
							<p class='text-[11px] uppercase tracking-[0.35em] text-[#8a7767] mb-2'>Escritura</p>
							<h2 class='text-3xl italic font-bold text-[#201611]'>Escribe tu relato</h2>
						</div>
						<div class='text-right'>
							<p class='text-[11px] uppercase tracking-[0.3em] text-[#8a7767] mb-2'>Palabras</p>
							<p id='word-count' data-word-count class='text-3xl font-bold text-[#201611]'>0</p>
						</div>
					</div>

					<form data-story-form class='space-y-5'>
						<label class='block'>
							<span class='mb-2 block text-[11px] uppercase tracking-[0.3em] text-[#8a7767]'>Título</span>
							<input
								data-story-title
								type='text'
								placeholder='Sin título'
								class='w-full rounded-2xl border border-[#dbc9b9] bg-white px-4 py-3 text-[#201611] outline-none transition focus:border-[#9f4f34] focus:ring-2 focus:ring-[#9f4f34]/10'
							/>
						</label>

						<label class='block'>
							<span class='mb-2 block text-[11px] uppercase tracking-[0.3em] text-[#8a7767]'>Autor</span>
							<input
								data-story-author
								type='text'
								placeholder='Anónimo'
								class='w-full rounded-2xl border border-[#dbc9b9] bg-white px-4 py-3 text-[#201611] outline-none transition focus:border-[#9f4f34] focus:ring-2 focus:ring-[#9f4f34]/10'
							/>
						</label>

						<label class='block'>
							<span class='mb-2 block text-[11px] uppercase tracking-[0.3em] text-[#8a7767]'>Relato</span>
							<textarea
								data-story-body
								rows='14'
								placeholder='Escribe aquí tu relato usando las 3 palabras del reto...'
								class='w-full rounded-3xl border border-[#dbc9b9] bg-white px-4 py-4 text-[#201611] outline-none transition focus:border-[#9f4f34] focus:ring-2 focus:ring-[#9f4f34]/10 resize-y'
							></textarea>
						</label>

						<div class='flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3'>
							<p data-save-status class='text-sm text-[#6e6259]'>El borrador se guarda automáticamente.</p>
							<button
								type='submit'
								class='inline-flex items-center justify-center rounded-full bg-[#9f4f34] px-6 py-3 text-sm font-semibold text-[#fffaf4] shadow-lg shadow-[#9f4f34]/25 transition hover:-translate-y-0.5 hover:bg-[#843e2a]'
							>
								Guardar relato
							</button>
						</div>
					</form>

					<section class='mt-10'>
						<div class='flex items-end justify-between gap-4 border-b border-[#dccaba] pb-4 mb-6'>
							<div>
								<p class='text-[11px] uppercase tracking-[0.35em] text-[#8a7767] mb-2'>Guardados</p>
								<h3 class='text-2xl italic font-bold text-[#201611]'>Tus relatos de hoy</h3>
							</div>
						</div>

						<div data-story-list class='grid gap-4'></div>
					</section>
				</div>
			</section>
		</section>
	</main>

	<script type='module'>
		import { initWriteStory } from '../scripts/write-story';
		initWriteStory();
	</script>
</Layout>
