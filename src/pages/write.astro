---
import AppHeader from '../components/AppHeader.astro';
import Layout from '../layouts/Layout.astro';
import { getFallbackDailyChallenge } from '../lib/challenge';

const challenge = getFallbackDailyChallenge();
---

<Layout
	title='PoetiKa - Escribir pagina'
	description='Escribe una pagina firmada con tu cuenta y publicala en el reto diario.'
>
	<main class='home-paper min-h-screen'>
		<div class='mx-auto max-w-[1420px] px-4 sm:px-8 lg:px-14'>
			<AppHeader currentPath='/write' />

			<div class='home-rail mx-auto max-w-[1390px]'>
				<section class='mx-auto grid max-w-[1180px] items-start gap-8 px-2 pb-20 pt-16 lg:grid-cols-[0.88fr_1.12fr] lg:px-4' data-write-page>
					<aside class='app-panel self-start p-7 sm:p-8'>
						<p class='app-kicker mb-4 text-[0.72rem] uppercase tracking-[0.32em]'>Reto actual</p>
						<h1 data-write-summary class='app-title serif mb-6 text-[2.8rem] font-semibold leading-none tracking-[-0.05em]'>
							{challenge.summary}
						</h1>

						<div class='space-y-4'>
							<div class='app-chip flex items-center gap-3 px-4 py-4'>
								<div class='flex h-10 w-10 items-center justify-center rounded-xl bg-[var(--surface-inverse)] text-sm font-semibold text-[var(--surface-base)]'>
									<span data-write-marker-1>{challenge.slots[0].marker}</span>
								</div>
								<div>
									<p data-write-category-1 class='text-[0.75rem] uppercase tracking-[0.24em] text-[var(--ink-muted)]'>{challenge.slots[0].category}</p>
									<p data-write-word-1 class='serif mt-1 text-[1.35rem] font-semibold text-[var(--ink-strong)]'>{challenge.slots[0].word}</p>
								</div>
							</div>
							<div class='app-chip flex items-center gap-3 px-4 py-4'>
								<div class='flex h-10 w-10 items-center justify-center rounded-xl bg-[var(--surface-inverse)] text-sm font-semibold text-[var(--surface-base)]'>
									<span data-write-marker-2>{challenge.slots[1].marker}</span>
								</div>
								<div>
									<p data-write-category-2 class='text-[0.75rem] uppercase tracking-[0.24em] text-[var(--ink-muted)]'>{challenge.slots[1].category}</p>
									<p data-write-word-2 class='serif mt-1 text-[1.35rem] font-semibold text-[var(--ink-strong)]'>{challenge.slots[1].word}</p>
								</div>
							</div>
							<div class='app-chip flex items-center gap-3 px-4 py-4'>
								<div class='flex h-10 w-10 items-center justify-center rounded-xl bg-[var(--surface-inverse)] text-sm font-semibold text-[var(--surface-base)]'>
									<span data-write-marker-3>{challenge.slots[2].marker}</span>
								</div>
								<div>
									<p data-write-category-3 class='text-[0.75rem] uppercase tracking-[0.24em] text-[var(--ink-muted)]'>{challenge.slots[2].category}</p>
									<p data-write-word-3 class='serif mt-1 text-[1.35rem] font-semibold text-[var(--ink-strong)]'>{challenge.slots[2].word}</p>
								</div>
							</div>
						</div>

						<div class='app-divider mt-8 border-t pt-5'>
							<div class='flex items-center justify-between gap-3'>
								<p class='text-[0.74rem] uppercase tracking-[0.24em] text-[var(--ink-muted)]'>Reto de hoy</p>
								<span class='app-chip rounded-full px-3 py-1 text-[0.74rem]' data-write-date>{challenge.dateKey}</span>
							</div>
							<p class='app-copy mt-4 text-sm leading-7'>
								Las palabras del reto se mantienen unificadas durante todo el dia y los relatos con likes ya viven en Supabase.
							</p>
							<p class='mt-3 text-[0.72rem] uppercase tracking-[0.24em] text-[var(--ink-muted)]'>
								<span data-write-source>seleccion local diaria</span>
							</p>
						</div>
					</aside>

					<div class='app-panel p-7 sm:p-9' data-editor-shell>
						<div class='app-divider mb-7 flex items-start justify-between gap-4 border-b pb-4'>
							<div>
								<p class='app-kicker mb-2 text-[0.72rem] uppercase tracking-[0.32em]'>Escritura</p>
								<h2 class='app-title serif text-[2.3rem] font-semibold tracking-[-0.04em]'>Publica tu pagina</h2>
							</div>
							<div class='text-right'>
								<p class='app-kicker mb-2 text-[0.72rem] uppercase tracking-[0.24em]'>Palabras</p>
								<p id='word-count' data-word-count class='app-title text-3xl font-semibold'>0</p>
							</div>
						</div>

						<form data-story-form class='space-y-5'>
							<label class='block'>
								<span class='app-kicker mb-2 block text-[0.72rem] uppercase tracking-[0.24em]'>Titulo</span>
								<input
									data-story-title
									type='text'
									placeholder='Sin titulo'
									class='app-input w-full px-4 py-3'
								/>
							</label>

							<div class='app-chip rounded-[1.75rem] px-4 py-3 text-sm leading-7'>
								Se publica como <span data-write-author class='font-semibold text-[var(--ink-strong)]'>Entrar para publicar</span>.
							</div>

							<label class='block'>
								<span class='app-kicker mb-2 block text-[0.72rem] uppercase tracking-[0.24em]'>Pagina</span>
								<textarea
									data-story-body
									rows='14'
									placeholder='Escribe aqui tu pagina usando las 3 palabras del reto...'
									class='app-input w-full resize-y px-4 py-4'
								></textarea>
							</label>

							<p data-required-words-status class='app-copy text-sm'>
								Tu pagina debe integrar estas 3 palabras.
							</p>

							<div class='flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between'>
								<p data-save-status class='app-copy text-sm'>El borrador se guarda automaticamente en este navegador.</p>
								<button
									type='submit'
									data-story-submit
									class='home-primary-button inline-flex items-center justify-center px-8 py-4 text-sm font-semibold'
								>
									Publicar pagina
								</button>
							</div>
						</form>

						<div data-auth-gate class='mt-5 app-panel rounded-[1.75rem] border-dashed p-5 text-sm leading-7 text-[var(--ink-soft)]'>
							Necesitas una cuenta para publicar o votar. <a href='/auth' class='font-semibold text-[var(--ink-strong)] underline underline-offset-4'>Entrar o crear cuenta</a>.
						</div>

						<section class='mt-10'>
							<div class='app-divider mb-6 flex items-end justify-between gap-4 border-b pb-4'>
								<div>
									<p class='app-kicker mb-2 text-[0.72rem] uppercase tracking-[0.32em]'>Publicados</p>
									<h3 class='app-title serif text-[2rem] font-semibold tracking-[-0.04em]'>Paginas del reto de hoy</h3>
								</div>
							</div>

							<div data-story-list class='grid gap-4'></div>
						</section>
					</div>
				</section>
			</div>
		</div>
	</main>

	<script>
		import { initWriteStory } from '../scripts/write-story.ts';
		initWriteStory();
	</script>
</Layout>
