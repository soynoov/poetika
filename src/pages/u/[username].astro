---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
	return [
		{ params: { username: 'demo' } },
		{ params: { username: 'heroyi' } },
		{ params: { username: 'tintaroja' } },
	];
}

const username = Astro.params.username ?? 'usuario';
---

<Layout title={`PoetiKa - @${username}`}>
	<main class='max-w-3xl mx-auto px-4 py-12'>
		<header class='mb-10'>
			<p class='text-xs uppercase tracking-[0.35em] text-slate-400 mb-3'>Perfil</p>
			<h1 class='text-5xl italic font-bold text-slate-800 mb-4'>@{username}</h1>
			<p class='text-slate-600 max-w-xl leading-relaxed'>
				Perfil de ejemplo para mostrar relatos, coronas y estadísticas de escritura.
			</p>
		</header>

		<section class='grid grid-cols-1 sm:grid-cols-3 gap-4'>
			<div class='bg-white border border-slate-200 p-5'>
				<p class='text-xs uppercase tracking-[0.2em] text-slate-400 mb-2'>Likes</p>
				<p class='text-3xl font-bold text-slate-800'>128</p>
			</div>
			<div class='bg-white border border-slate-200 p-5'>
				<p class='text-xs uppercase tracking-[0.2em] text-slate-400 mb-2'>Coronas</p>
				<p class='text-3xl font-bold text-slate-800'>4</p>
			</div>
			<div class='bg-white border border-slate-200 p-5'>
				<p class='text-xs uppercase tracking-[0.2em] text-slate-400 mb-2'>Racha</p>
				<p class='text-3xl font-bold text-slate-800'>7 días</p>
			</div>
		</section>
	</main>
</Layout>
