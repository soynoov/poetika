---
import AppHeader from '../../components/AppHeader.astro';
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
	return [
		{ params: { username: 'demo' } },
		{ params: { username: 'heroyi' } },
		{ params: { username: 'tintaroja' } },
	];
}

const username = Astro.params.username ?? 'usuario';
---

<Layout title={`PoetiKa - @${username}`}>
	<main class='home-paper min-h-screen'>
		<div class='mx-auto max-w-[1420px] px-4 sm:px-8 lg:px-14'>
			<AppHeader currentPath='/u/demo' />

			<div class='home-rail mx-auto max-w-[1390px]'>
				<section class='mx-auto max-w-[980px] px-2 pb-20 pt-16 sm:px-4'>
					<header class='app-divider mb-10 border-b pb-6'>
						<p class='app-kicker mb-3 text-[0.72rem] uppercase tracking-[0.32em]'>Perfil</p>
						<h1 class='app-title serif text-[3.6rem] font-semibold tracking-[-0.05em]'>@{username}</h1>
						<p class='app-copy mt-4 max-w-2xl text-base leading-8'>
							Perfil de ejemplo para mostrar relatos, coronas y estadisticas de escritura.
						</p>
					</header>

					<section class='grid grid-cols-1 gap-4 sm:grid-cols-3'>
						<div class='app-panel p-6'>
							<p class='app-kicker mb-2 text-[0.72rem] uppercase tracking-[0.24em]'>Likes</p>
							<p class='app-title text-4xl font-semibold'>128</p>
						</div>
						<div class='app-panel p-6'>
							<p class='app-kicker mb-2 text-[0.72rem] uppercase tracking-[0.24em]'>Coronas</p>
							<p class='app-title text-4xl font-semibold'>4</p>
						</div>
						<div class='app-panel p-6'>
							<p class='app-kicker mb-2 text-[0.72rem] uppercase tracking-[0.24em]'>Racha</p>
							<p class='app-title text-4xl font-semibold'>7 dias</p>
						</div>
					</section>
				</section>
			</div>
		</div>
	</main>
</Layout>
