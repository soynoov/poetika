---
import AppHeader from '../components/AppHeader.astro';
import Layout from '../layouts/Layout.astro';
import { getFallbackDailyChallenge } from '../lib/challenge';

const challenge = getFallbackDailyChallenge();
---

<Layout
	title='PoetiKa - Feed del momento'
	description='Feed del reto activo de 5 minutos con perfiles reales, likes persistentes y publicacion inmediata.'
>
	<main class='home-paper min-h-screen'>
		<div class='mx-auto max-w-[1420px] px-4 sm:px-8 lg:px-14'>
			<AppHeader currentPath='/all' />

			<div class='home-rail mx-auto max-w-[1390px]'>
				<section class='mx-auto grid max-w-[1180px] gap-8 px-2 pb-20 pt-16 lg:grid-cols-[0.78fr_1.22fr] lg:px-4'>
					<aside class='app-panel self-start p-7 sm:p-8'>
						<p class='app-kicker mb-4 text-[0.72rem] uppercase tracking-[0.32em]'>Reto activo</p>
						<h1 class='app-title serif mb-6 text-[2.7rem] font-semibold leading-none tracking-[-0.05em]'>
							{challenge.summary}
						</h1>

						<div class='space-y-4'>
							{challenge.slots.map((slot) => (
								<div class='app-chip px-4 py-4'>
									<p class='text-[0.75rem] uppercase tracking-[0.24em] text-[var(--ink-muted)]'>{slot.category}</p>
									<p class='serif mt-2 text-[1.45rem] font-semibold capitalize text-[var(--ink-strong)]'>{slot.word}</p>
								</div>
							))}
						</div>

						<div class='app-divider mt-8 border-t pt-5'>
							<p class='text-[0.74rem] uppercase tracking-[0.24em] text-[var(--ink-muted)]'>Fecha</p>
							<p class='app-title mt-2 text-lg'>{challenge.dateKey}</p>
							<p class='app-copy mt-3 text-sm leading-7'>
								El feed enseña los relatos del reto activo. Los likes persisten y reordenan el listado al instante.
							</p>
						</div>
					</aside>

					<section class='app-panel p-7 sm:p-9'>
						<div class='app-divider mb-7 flex flex-col gap-4 border-b pb-4 md:flex-row md:items-end md:justify-between'>
							<div>
								<p class='app-kicker mb-2 text-[0.72rem] uppercase tracking-[0.32em]'>Feed del momento</p>
								<h2 class='app-title serif text-[2.4rem] font-semibold tracking-[-0.04em]'>Relatos en juego</h2>
							</div>
							<div class='app-chip rounded-full px-4 py-2 text-sm'>
								<span class='font-semibold text-[var(--ink-strong)]' data-story-total>0</span> publicados ahora
							</div>
						</div>

						<div data-story-feed data-feed-mode='full' class='grid gap-5'></div>
					</section>
				</section>
			</div>
		</div>
	</main>

	<script type='module'>
		import { initStoryFeed } from '../scripts/story-feed.ts';

		initStoryFeed();
	</script>
</Layout>
