---
import AppHeader from '../components/AppHeader.astro';
import { getChallengeIcon } from '../lib/challenge-icons';
import KoFiWidget from '../components/KoFiWidget.astro';
import { koFiUrl, koFiWidget } from '../lib/support';
import Layout from '../layouts/Layout.astro';
import { getFallbackDailyChallenge } from '../lib/challenge';

const challenge = getFallbackDailyChallenge();
---

<Layout
  title='PoetiKa - Inicio'
  description='PoetiKa muestra el reto activo y los relatos publicados en una home simple centrada en la app.'
>
  <main class='home-paper min-h-screen text-(--ink-strong)'>
    <div class='mx-auto max-w-355 px-4 sm:px-8 lg:px-14'>
      <AppHeader currentPath='/' />

      <div class='home-rail mx-auto w-full max-w-347.5'>
        <section
          class='mx-auto max-w-280 px-2 pb-10 pt-18 text-center sm:px-4 sm:pt-20'
        >
          <p class='app-kicker mb-4 text-[0.72rem] uppercase tracking-[0.32em]'>
            Reto activo
          </p>
          <h1
            class='app-title serif text-[3.2rem] font-semibold leading-none tracking-[-0.05em] sm:text-[4.7rem]'
          >
            Reto del dia
          </h1>
          <p
            class='app-kicker mt-4 text-[0.88rem] uppercase tracking-[0.23em] sm:text-[1.02rem]'
          >
            Acepta el desafio y escribe tu historia
          </p>

          <div class='mt-16 grid gap-6 lg:grid-cols-3'>
            {
              challenge.slots.map((slot, index) => {
                const icon = getChallengeIcon(slot.category);

                return (
                  <article
                    data-daily-slot={index}
                    class='home-challenge-card flex min-h-62.5 flex-col items-center justify-center bg-(--surface-soft) px-8 py-10 text-center'
                  >
                    <svg
                      viewBox='0 0 24 24'
                      class='mb-9 h-11 w-11 text-(--ink-strong)'
                      fill='none'
                      stroke='currentColor'
                      stroke-width='1.8'
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      aria-hidden='true'
                    >
                      <path d={icon.path} />
                    </svg>
                    <p
                      data-daily-category
                      class='mb-2 text-[0.9rem] uppercase tracking-[0.24em] text-(--ink-muted)'
                    >
                      {slot.category}
                    </p>
                    <div class='mb-4 h-px w-16 bg-(--frame-border)' />
                    <p
                      data-daily-word
                      class='app-title serif text-[2.05rem] font-semibold leading-tight tracking-[-0.03em] sm:text-[2.45rem]'
                    >
                      {slot.word}
                    </p>
                    <span data-daily-marker class='hidden'>
                      {slot.marker}
                    </span>
                  </article>
                );
              })
            }
          </div>

          <div class='mt-14'>
            <a
              href='/write'
              class='home-primary-button inline-flex min-w-[18.5rem] items-center justify-center px-8 py-4 text-[0.98rem] font-semibold transition hover:-translate-y-0.5'
            >
              Escribe tu relato
            </a>
          </div>
        </section>

        <section class='mx-auto max-w-225 px-2 pb-20 pt-18 sm:px-4'>
          <div
            class='app-divider mb-8 flex items-end justify-between gap-4 border-b pb-3'
          >
            <h2
              class='app-title serif text-[2.2rem] font-semibold leading-none tracking-[-0.04em] sm:text-[3.2rem]'
            >
              Relatos de hoy
            </h2>
            <a
              href='/all'
              class='pb-1 text-[1rem] text-(--ink-muted) transition hover:text-(--ink-strong)'
            >
              Ver todos
            </a>
          </div>

          <div
            data-story-feed
            data-feed-mode='home-editorial'
            class='grid gap-9'
          >
          </div>

          {(koFiUrl || koFiWidget) && (
            <div class='mt-10 app-panel rounded-[2rem] px-7 py-6'>
              <p class='app-kicker mb-2 text-[0.72rem] uppercase tracking-[0.3em]'>
                Ko-fi
              </p>
              <div class='flex flex-col gap-4 md:flex-row md:items-center md:justify-between'>
                <p class='app-copy max-w-2xl text-sm leading-7'>
                  Apoya Poetika para seguir puliendo la experiencia de escritura, perfiles y retos.
                </p>
                {koFiWidget ? (
                  <KoFiWidget class='kofi-widget-shell self-start md:self-center' />
                ) : (
                  <a
                    href={koFiUrl}
                    target='_blank'
                    rel='noreferrer'
                    class='app-link-button inline-flex items-center justify-center rounded-full border border-[var(--frame-border)] bg-[var(--surface-strong)] px-5 py-3 text-sm font-semibold text-[var(--ink-strong)] transition hover:bg-[var(--surface-hover)]'
                  >
                    Apoyar en Ko-fi
                  </a>
                )}
              </div>
            </div>
          )}
        </section>
      </div>
    </div>
  </main>

  <script>
    import { initDailyChallenge } from '../scripts/daily-challenge.ts';
    import { initStoryFeed } from '../scripts/story-feed.ts';

    initDailyChallenge();
    initStoryFeed();
  </script>
</Layout>
